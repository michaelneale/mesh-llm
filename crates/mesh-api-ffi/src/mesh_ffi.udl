namespace mesh_ffi {
    [Throws=FfiError]
    MeshClientHandle create_client(string owner_keypair_bytes_hex, string invite_token);

    [Throws=FfiError]
    MeshClientHandle create_auto_client(string owner_keypair_bytes_hex, PublicMeshQueryDto query);

    [Throws=FfiError]
    sequence<PublicMeshDto> discover_public_meshes(PublicMeshQueryDto query);

    string generate_owner_keypair_hex();
};

[Error]
enum FfiError {
    "InvalidInviteToken",
    "InvalidOwnerKeypair",
    "BuildFailed",
    "JoinFailed",
    "DiscoveryFailed",
    "StreamFailed",
    "Cancelled",
    "ReconnectFailed",
    "HostUnavailable",
};

interface MeshClientHandle {
    [Throws=FfiError]
    void join();

    [Throws=FfiError]
    sequence<ModelDto> list_models();

    string chat(ChatRequestDto request, EventListener listener);

    string responses(ResponsesRequestDto request, EventListener listener);

    string add_event_listener(EventListener listener);

    void remove_event_listener(string listener_id);

    void cancel(string request_id);

    StatusDto status();

    void disconnect();

    [Throws=FfiError]
    void reconnect();
};

callback interface EventListener {
    void on_event(EventDto event);
};

dictionary ModelDto {
    string id;
    string name;
};

dictionary StatusDto {
    boolean connected;
    u64 peer_count;
};

dictionary PublicMeshQueryDto {
    string? model;
    double? min_vram_gb;
    string? region;
    string? target_name;
    sequence<string> relays;
};

dictionary PublicMeshDto {
    string invite_token;
    sequence<string> serving;
    sequence<string> wanted;
    sequence<string> on_disk;
    u64 total_vram_bytes;
    u64 node_count;
    u64 client_count;
    u64 max_clients;
    string? name;
    string? region;
    string? mesh_id;
    string publisher_npub;
    u64 published_at;
    u64? expires_at;
};

dictionary ChatRequestDto {
    string model;
    sequence<ChatMessageDto> messages;
};

dictionary ChatMessageDto {
    string role;
    string content;
};

dictionary ResponsesRequestDto {
    string model;
    string input;
};

[Enum]
interface EventDto {
    Connecting();
    Joined(string node_id);
    ModelsUpdated(sequence<ModelDto> models);
    TokenDelta(string request_id, string delta);
    Completed(string request_id);
    Failed(string request_id, string error);
    Disconnected(string reason);
};
