From 8796d07e36d738b1bf59f959fc5d97607bc72c09 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 2 May 2026 08:46:13 +1000
Subject: [PATCH] Build stage ABI TurboQuant helpers

---
 ggml/src/CMakeLists.txt | 1 +
 ggml/src/ggml.c         | 6 ++++++
 2 files changed, 7 insertions(+)

diff --git a/ggml/src/CMakeLists.txt b/ggml/src/CMakeLists.txt
index 52754e1b..4bcb9c80 100644
--- a/ggml/src/CMakeLists.txt
+++ b/ggml/src/CMakeLists.txt
@@ -206,6 +206,7 @@ add_library(ggml-base
             ggml-threading.h
             ggml-quants.c
             ggml-quants.h
+            ggml-turbo-quant.c
             gguf.cpp)
 
 set_target_properties(ggml-base PROPERTIES
diff --git a/ggml/src/ggml.c b/ggml/src/ggml.c
index e93c0040..d9e5e37d 100644
--- a/ggml/src/ggml.c
+++ b/ggml/src/ggml.c
@@ -33,6 +33,7 @@
 #include <limits.h>
 #include <stdarg.h>
 #include <signal.h>
+#include <stdatomic.h>
 #if defined(__gnu_linux__)
 #include <syscall.h>
 #endif
@@ -53,6 +54,11 @@
 
 #define UNUSED GGML_UNUSED
 
+uint64_t ggml_graph_next_uid(void) {
+    static _Atomic uint64_t next_uid = 1;
+    return atomic_fetch_add(&next_uid, 1);
+}
+
 // Needed for ggml_fp32_to_bf16_row()
 #if defined(__AVX512BF16__)
 #if defined(_MSC_VER)
-- 
