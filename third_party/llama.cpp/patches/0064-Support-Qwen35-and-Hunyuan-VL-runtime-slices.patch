From bafce583559344e513bca5355d56b2e4ba91e30c Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Wed, 6 May 2026 20:10:14 +1000
Subject: [PATCH 64/80] Support Qwen35 and Hunyuan-VL runtime slices

---
 src/models/qwen35.cpp | 32 ++++++++++++++++++++++++++------
 src/skippy.cpp        |  2 ++
 2 files changed, 28 insertions(+), 6 deletions(-)

diff --git a/src/models/qwen35.cpp b/src/models/qwen35.cpp
index 35a0158e..97ae07d3 100644
--- a/src/models/qwen35.cpp
+++ b/src/models/qwen35.cpp
@@ -148,18 +148,31 @@ llama_model_qwen35::graph::graph(const llama_model & model, const llm_graph_para
     ggml_tensor * cur;
     ggml_tensor * inpL;
 
-    inpL = build_inp_embd(model.tok_embd);
+    // MTP/NextN layers are loaded as extra decoder blocks but not executed in the main pass.
+    const int n_transformer_layers = n_layer - (int) hparams.nextn_predict_layers;
+
+    const skippy_graph_filter & stage_filter = skippy_graph_get_filter();
+    const bool stage_filtered = stage_filter.enabled;
+    const int il_start = stage_filtered ? std::min(stage_filter.layer_start, n_transformer_layers) : 0;
+    const int il_end   = stage_filtered ? std::min(stage_filter.layer_end,   n_transformer_layers) : n_transformer_layers;
+    bool has_attention_layer = false;
+    for (int il = il_start; il < il_end; ++il) {
+        if (!hparams.is_recurrent(il)) {
+            has_attention_layer = true;
+            break;
+        }
+    }
+
+    inpL = build_inp_embd(stage_filtered && il_start > 0 ? nullptr : model.tok_embd);
 
     cb(inpL, "model.input_embed", -1);
 
     auto * inp = build_inp_mem_hybrid();
 
-    ggml_tensor * inp_pos     = build_inp_pos();
-    ggml_tensor * inp_out_ids = build_inp_out_ids();
+    ggml_tensor * inp_pos     = has_attention_layer ? build_inp_pos() : nullptr;
+    ggml_tensor * inp_out_ids = (!stage_filtered || stage_filter.include_output) ? build_inp_out_ids() : nullptr;
 
-    // MTP/NextN layers are loaded as extra decoder blocks but not executed in the main pass.
-    const int n_transformer_layers = n_layer - (int) hparams.nextn_predict_layers;
-    for (int il = 0; il < n_transformer_layers; ++il) {
+    for (int il = il_start; il < il_end; ++il) {
         ggml_tensor * inpSA = inpL;
 
         cur = build_norm(inpL, model.layers[il].attn_norm, nullptr, LLM_NORM_RMS, il);
@@ -208,6 +221,13 @@ llama_model_qwen35::graph::graph(const llama_model & model, const llm_graph_para
     }
     cur = inpL;
 
+    if (stage_filtered && !stage_filter.include_output) {
+        cb(cur, "stage_boundary", il_end - 1);
+        res->t_embd = cur;
+        ggml_build_forward_expand(gf, cur);
+        return;
+    }
+
     cb(cur, "h_pre_norm", -1);
     res->t_h_pre_norm = cur;
 
diff --git a/src/skippy.cpp b/src/skippy.cpp
index a2a44cbe..5da8f5a7 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1590,6 +1590,7 @@ static enum skippy_status skippy_finish_model_open(
             model->arch != LLM_ARCH_GRANITE_MOE &&
             model->arch != LLM_ARCH_HUNYUAN_DENSE &&
             model->arch != LLM_ARCH_HUNYUAN_MOE &&
+            model->arch != LLM_ARCH_HUNYUAN_VL &&
             model->arch != LLM_ARCH_INTERNLM2 &&
             model->arch != LLM_ARCH_JAMBA &&
             model->arch != LLM_ARCH_LFM2 &&
@@ -1605,6 +1606,7 @@ static enum skippy_status skippy_finish_model_open(
             model->arch != LLM_ARCH_QWEN2VL &&
             model->arch != LLM_ARCH_QWEN3VL &&
             model->arch != LLM_ARCH_QWEN2MOE &&
+            model->arch != LLM_ARCH_QWEN35 &&
             model->arch != LLM_ARCH_QWEN35MOE &&
             model->arch != LLM_ARCH_QWEN3MOE &&
             model->arch != LLM_ARCH_RWKV6 &&
