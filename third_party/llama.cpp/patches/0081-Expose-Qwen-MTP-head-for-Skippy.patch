+    if (session == nullptr || session->ctx == nullptr || session->stage_model == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    const int32_t n_embd = llama_model_n_embd(session->stage_model->model);
+    const size_t bytes = static_cast<size_t>(token_count) * static_cast<size_t>(n_embd) * sizeof(float);
+    if (out_output_bytes != nullptr) {
+        *out_output_bytes = bytes;
+    }
+    if (output_payload == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_BUFFER_TOO_SMALL, "pre-norm output buffer is required");
+        return SKIPPY_STATUS_BUFFER_TOO_SMALL;
+    }
+    if (output_capacity < bytes) {
+        skippy_set_error(out_error, SKIPPY_STATUS_BUFFER_TOO_SMALL, "pre-norm output buffer is too small");
+        return SKIPPY_STATUS_BUFFER_TOO_SMALL;
+    }
+    float * h = llama_get_embeddings_pre_norm(session->ctx);
+    if (h == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "pre-norm embeddings were not captured");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    memcpy(output_payload, h, bytes);
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_head_open(
+        const char * path,
+        const struct skippy_runtime_config * target_config,
+        const struct skippy_mtp_params * params_in,
+        struct skippy_mtp_head ** out_head,
+        struct skippy_error ** out_error) {
+    if (path == nullptr || out_head == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "path and out_head are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    *out_head = nullptr;
+
+    const std::string mtp_arch = skippy_mtp_arch_for_path(path);
+    if (mtp_arch.empty()) {
+        skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "GGUF does not advertise a supported MTP head");
+        return SKIPPY_STATUS_UNSUPPORTED;
+    }
+
+    llama_model_params mparams = llama_model_default_params();
+    mparams.override_arch = mtp_arch.c_str();
+    if (target_config != nullptr) {
+        mparams.n_gpu_layers = target_config->n_gpu_layers;
+        if (target_config->disable_repack || target_config->filter_tensors_on_load) {
+            mparams.use_extra_bufts = false;
+        }
+    }
+
+    llama_backend_init();
+    std::vector<ggml_backend_dev_t> selected_devices;
+    enum skippy_status device_status = skippy_apply_selected_backend_device(target_config, mparams, selected_devices, out_error);
+    if (device_status != SKIPPY_STATUS_OK) {
+        return device_status;
+    }
+
+    llama_model * model = llama_model_load_from_file(path, mparams);
+    if (model == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_MODEL_ERROR, "failed to load MTP head");
+        return SKIPPY_STATUS_MODEL_ERROR;
+    }
+
+    llama_context_params cparams = llama_context_default_params();
+    cparams.n_ctx = target_config != nullptr && target_config->ctx_size > 0 ? static_cast<uint32_t>(target_config->ctx_size) : 512;
+    cparams.n_batch = target_config != nullptr && target_config->n_batch > 0 ? static_cast<uint32_t>(target_config->n_batch) : cparams.n_ctx;
+    cparams.n_ubatch = target_config != nullptr && target_config->n_ubatch > 0 ? static_cast<uint32_t>(target_config->n_ubatch) : 0u;
+    cparams.n_threads = target_config != nullptr && target_config->n_threads > 0 ? target_config->n_threads : skippy_default_thread_count();
+    cparams.n_threads_batch = target_config != nullptr && target_config->n_threads_batch > 0 ? target_config->n_threads_batch : cparams.n_threads;
+    cparams.n_seq_max = 1;
+    cparams.type_k = target_config != nullptr && target_config->cache_type_k > 0 ? static_cast<ggml_type>(target_config->cache_type_k) : GGML_TYPE_F16;
+    cparams.type_v = target_config != nullptr && target_config->cache_type_v > 0 ? static_cast<ggml_type>(target_config->cache_type_v) : GGML_TYPE_F16;
+    cparams.flash_attn_type = target_config != nullptr ? static_cast<llama_flash_attn_type>(target_config->flash_attn_type) : LLAMA_FLASH_ATTN_TYPE_AUTO;
+
+    llama_context * ctx = llama_init_from_model(model, cparams);
+    if (ctx == nullptr) {
+        llama_model_free(model);
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "failed to create MTP context");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    llama_set_embeddings_pre_norm(ctx, true);
+
+    skippy_mtp_head * head = new skippy_mtp_head{};
+    head->model = model;
+    head->ctx = ctx;
+    head->n_embd = llama_model_n_embd(model);
+    head->params = params_in != nullptr ? *params_in : skippy_mtp_params{};
+    if (head->params.n_max == 0) {
+        head->params.n_max = 3;
+    }
+    if (head->params.top_k == 0) {
+        head->params.top_k = 10;
+    }
+    if (head->params.p_min <= 0.0f) {
+        head->params.p_min = 0.5f;
+    }
+    *out_head = head;
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_head_free(
+        struct skippy_mtp_head * head,
+        struct skippy_error ** out_error) {
+    if (head != nullptr) {
+        if (head->ctx != nullptr) {
+            llama_free(head->ctx);
+        }
+        if (head->model != nullptr) {
+            llama_model_free(head->model);
+        }
+        delete head;
+    }
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_session_create(
+        struct skippy_mtp_head * head,
+        struct skippy_mtp_session ** out_session,
+        struct skippy_error ** out_error) {
+    if (head == nullptr || out_session == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "head and out_session are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    skippy_mtp_session * session = new skippy_mtp_session{};
+    session->head = head;
+    session->h_work.assign(static_cast<size_t>(head->n_embd), 0.0f);
+    session->h_pending.assign(static_cast<size_t>(head->n_embd), 0.0f);
+    *out_session = session;
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_session_free(
+        struct skippy_mtp_session * session,
+        struct skippy_error ** out_error) {
+    delete session;
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_session_reset(
+        struct skippy_mtp_session * session,
+        struct skippy_error ** out_error) {
+    if (session == nullptr || session->head == nullptr || session->head->ctx == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "valid MTP session is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    llama_memory_clear(llama_get_memory(session->head->ctx), true);
+    session->n_past = 0;
+    std::fill(session->h_pending.begin(), session->h_pending.end(), 0.0f);
+    session->has_pending = false;
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_session_ingest(
+        struct skippy_mtp_session * session,
+        const llama_token * token_ids,
+        size_t token_count,
+        const void * h_pre_norm_f32,
+        size_t h_pre_norm_bytes,
+        llama_pos pos_start,
+        struct skippy_error ** out_error) {
+    if (session == nullptr || session->head == nullptr || session->head->ctx == nullptr || token_ids == nullptr || h_pre_norm_f32 == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session, token_ids, and h_pre_norm_f32 are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    skippy_mtp_head * head = session->head;
+    const size_t row_bytes = static_cast<size_t>(head->n_embd) * sizeof(float);
+    if (token_count == 0 || h_pre_norm_bytes != token_count * row_bytes) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "invalid MTP ingest token count or hidden rows");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    const float * h_rows = static_cast<const float *>(h_pre_norm_f32);
+    llama_batch batch = llama_batch_init(static_cast<int32_t>(token_count), head->n_embd, 1);
+    if (batch.token == nullptr) {
+        batch.token = (llama_token *) malloc(sizeof(llama_token) * token_count);
+    }
+    batch.n_tokens = static_cast<int32_t>(token_count);
+    for (int32_t i = 0; i < batch.n_tokens; ++i) {
+        batch.token[i] = token_ids[i];
+        batch.pos[i] = pos_start + i;
+        batch.n_seq_id[i] = 1;
+        batch.seq_id[i][0] = 0;
+        batch.logits[i] = 0;
+        const float * h_src = nullptr;
+        if (i == 0) {
+            h_src = session->has_pending ? session->h_pending.data() : session->h_work.data();
+        } else {
+            h_src = h_rows + static_cast<size_t>(i - 1) * head->n_embd;
+        }
+        memcpy(batch.embd + static_cast<size_t>(i) * head->n_embd, h_src, row_bytes);
+    }
+    const int rc = llama_decode(head->ctx, batch);
+    llama_batch_free(batch);
+    if (rc != 0) {
+        char message[256];
+        const llama_pos pos_max = llama_memory_seq_pos_max(llama_get_memory(head->ctx), 0);
+        snprintf(
+                message,
+                sizeof(message),
+                "MTP ingest decode failed: rc=%d pos_start=%d token_count=%zu session_n_past=%d mem_pos_max=%d",
+                rc,
+                static_cast<int>(pos_start),
+                token_count,
+                session->n_past,
+                static_cast<int>(pos_max));
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, message);
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    memcpy(session->h_pending.data(), h_rows + (token_count - 1) * static_cast<size_t>(head->n_embd), row_bytes);
+    session->has_pending = true;
+    session->n_past = static_cast<int32_t>(pos_start + static_cast<llama_pos>(token_count));
+    return skippy_success(out_error);
+}
+
+enum skippy_status skippy_mtp_session_draft(
+        struct skippy_mtp_session * session,
+        const void * h_pre_norm_f32,
+        size_t h_pre_norm_bytes,
+        llama_token last_token,
+        llama_pos position,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_draft_result * out_result,
+        struct skippy_error ** out_error) {
+    if (out_result != nullptr) {
+        *out_result = {};
+        out_result->version = 1;
+    }
+    if (session == nullptr || session->head == nullptr || h_pre_norm_f32 == nullptr || output_tokens == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session, h_pre_norm_f32, and output_tokens are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    skippy_mtp_head * head = session->head;
+    const size_t row_bytes = static_cast<size_t>(head->n_embd) * sizeof(float);
+    if (h_pre_norm_bytes != row_bytes || output_token_capacity == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "invalid MTP hidden row or output capacity");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    memcpy(session->h_work.data(), h_pre_norm_f32, row_bytes);
+    enum skippy_status reset_status = skippy_mtp_session_reset(session, out_error);
+    if (reset_status != SKIPPY_STATUS_OK) {
+        return reset_status;
+    }
+    memcpy(session->h_pending.data(), h_pre_norm_f32, row_bytes);
+    session->has_pending = true;
+    return skippy_mtp_session_draft_synced(
+            session,
+            last_token,
+            position,
+            output_tokens,
+            output_token_capacity,
+            out_result,
+            out_error);
+}
+
+enum skippy_status skippy_mtp_session_draft_synced(
+        struct skippy_mtp_session * session,
+        llama_token last_token,
+        llama_pos position,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_draft_result * out_result,
+        struct skippy_error ** out_error) {
+    if (out_result != nullptr) {
+        *out_result = {};
+        out_result->version = 1;
+    }
+    if (session == nullptr || session->head == nullptr || output_tokens == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session and output_tokens are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (!session->has_pending) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "MTP session has not been synchronized");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    skippy_mtp_head * head = session->head;
+    const size_t row_bytes = static_cast<size_t>(head->n_embd) * sizeof(float);
+    if (output_token_capacity == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "invalid MTP output capacity");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    const int32_t checkpoint_n_past = session->n_past;
+    const std::vector<float> checkpoint_pending = session->h_pending;
+
+    const size_t n_max = std::min<size_t>(output_token_capacity, head->params.n_max);
+    const int32_t n_vocab = llama_vocab_n_tokens(llama_model_get_vocab(head->model));
+    uint32_t drafted = 0;
+    llama_token token = last_token;
+    for (; drafted < n_max; ++drafted) {
+        llama_batch batch = llama_batch_init(1, head->n_embd, 1);
+        if (batch.token == nullptr) {
+            batch.token = (llama_token *) malloc(sizeof(llama_token));
+        }
+        batch.n_tokens = 1;
+        batch.token[0] = token;
+        memcpy(batch.embd, session->h_work.data(), row_bytes);
+        memcpy(batch.embd, session->h_pending.data(), row_bytes);
+        batch.pos[0] = position + static_cast<llama_pos>(drafted);
+        batch.n_seq_id[0] = 1;
+        batch.seq_id[0][0] = 0;
+        batch.logits[0] = 1;
+
+        const int rc = llama_decode(head->ctx, batch);
+        llama_batch_free(batch);
+        if (rc != 0) {
+            char message[256];
+            const llama_pos pos_max = llama_memory_seq_pos_max(llama_get_memory(head->ctx), 0);
+            snprintf(
+                    message,
+                    sizeof(message),
+                    "MTP decode failed: rc=%d draft_index=%u position=%d checkpoint_n_past=%d session_n_past=%d mem_pos_max=%d",
+                    rc,
+                    drafted,
+                    static_cast<int>(position + static_cast<llama_pos>(drafted)),
+                    checkpoint_n_past,
+                    session->n_past,
+                    static_cast<int>(pos_max));
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, message);
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+
+        const float * logits = llama_get_logits_ith(head->ctx, 0);
+        if (logits == nullptr) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "MTP logits were not available");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+        llama_token best = 0;
+        float best_logit = logits[0];
+        for (int32_t i = 1; i < n_vocab; ++i) {
+            if (logits[i] > best_logit) {
+                best = i;
+                best_logit = logits[i];
+            }
+        }
+        if (skippy_mtp_top_probability(logits, n_vocab, best, head->params.top_k) < head->params.p_min) {
+            break;
+        }
+        output_tokens[drafted] = best;
+        token = best;
+        float * h_next = llama_get_embeddings_pre_norm_ith(head->ctx, 0);
+        if (h_next == nullptr) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "MTP pre-norm output was not available");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+        memcpy(session->h_pending.data(), h_next, row_bytes);
+    }
+
+    if (!llama_memory_seq_rm(llama_get_memory(head->ctx), 0, checkpoint_n_past, -1)) {
+        char message[256];
+        const llama_pos pos_max = llama_memory_seq_pos_max(llama_get_memory(head->ctx), 0);
+        snprintf(
+                message,
+                sizeof(message),
+                "failed to trim MTP draft context: checkpoint_n_past=%d mem_pos_max=%d",
+                checkpoint_n_past,
+                static_cast<int>(pos_max));
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, message);
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    session->n_past = checkpoint_n_past;
+    session->h_pending = checkpoint_pending;
+    session->has_pending = true;
+
+    if (out_result != nullptr) {
+        out_result->token_count = drafted;
+        out_result->accepted_floor = std::min<uint32_t>(drafted, head->params.n_min);
+    }
+    return skippy_success(out_error);
+}
