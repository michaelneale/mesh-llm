+enum skippy_status skippy_mtp_decode_step(
+        struct skippy_session * target_session,
+        struct skippy_mtp_session * mtp_session,
+        llama_token input_token,
+        const struct skippy_sampling_config * sampling,
+        size_t max_new_tokens,
+        size_t max_speculative_tokens,
+        bool mtp_enabled,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_decode_result * out_result,
+        struct skippy_error ** out_error) {
+    if (out_result != nullptr) {
+        *out_result = {};
+        out_result->version = 1;
+    }
+    if (target_session == nullptr || target_session->ctx == nullptr || output_tokens == nullptr || out_result == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "target_session, output_tokens, and out_result are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (max_new_tokens == 0 || output_token_capacity == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "max_new_tokens and output capacity must be non-zero");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    const llama_vocab * vocab = llama_model_get_vocab(target_session->stage_model->model);
+
+    const int64_t decode_start_us = ggml_time_us();
+    enum skippy_status status = skippy_decode_tokens(target_session, &input_token, 1, true, out_error);
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    out_result->target_decode_calls += 1;
+    const llama_token current = skippy_sample_token(target_session, sampling);
+    out_result->target_decode_ms += static_cast<double>(ggml_time_us() - decode_start_us) / 1000.0;
+    output_tokens[0] = current;
+    out_result->committed_count = 1;
+
+    if (!mtp_enabled || mtp_session == nullptr || max_new_tokens <= 1 || max_speculative_tokens == 0 || llama_vocab_is_eog(vocab, current)) {
+        if (!mtp_enabled) {
+            out_result->mtp_disabled = 1;
+        }
+        return skippy_success(out_error);
+    }
+    if (mtp_session->head == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "MTP session head is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    const int64_t ingest_start_us = ggml_time_us();
+    float * h_decode = llama_get_embeddings_pre_norm(target_session->ctx);
+    if (h_decode == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "target pre-norm embeddings were not captured for fused MTP decode");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    const llama_pos input_pos = target_session->n_past - 1;
+    status = skippy_mtp_session_ingest(
+            mtp_session,
+            &input_token,
+            1,
+            h_decode,
+            static_cast<size_t>(mtp_session->head->n_embd) * sizeof(float),
+            input_pos,
+            out_error);
+    out_result->mtp_ingest_ms += static_cast<double>(ggml_time_us() - ingest_start_us) / 1000.0;
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    out_result->mtp_ingest_calls += 1;
+    out_result->mtp_ingest_tokens += 1;
+
+    const size_t proposal_limit = max_new_tokens > 2 ? std::min(max_speculative_tokens, max_new_tokens - 2) : 0;
+    if (proposal_limit == 0) {
+        return skippy_success(out_error);
+    }
+    std::vector<llama_token> draft_tokens(proposal_limit);
+    skippy_mtp_draft_result draft_result{};
+    const int64_t propose_start_us = ggml_time_us();
+    out_result->mtp_draft_calls += 1;
+    status = skippy_mtp_session_draft_synced(
+            mtp_session,
+            current,
+            target_session->n_past,
+            draft_tokens.data(),
+            draft_tokens.size(),
+            &draft_result,
+            out_error);
+    out_result->mtp_propose_ms += static_cast<double>(ggml_time_us() - propose_start_us) / 1000.0;
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    draft_tokens.resize(draft_result.token_count);
+    out_result->mtp_draft_decode_calls += draft_result.token_count;
+    out_result->mtp_draft_tokens += draft_result.token_count;
+
+    if (draft_tokens.empty()) {
+        return skippy_success(out_error);
+    }
+    out_result->proposed_tokens = draft_result.token_count;
+    const bool verify_extra_sample = max_speculative_tokens > 1;
+    const size_t max_output_tokens = 1 + draft_tokens.size() + (verify_extra_sample ? 1 : 0);
+    if (output_token_capacity < max_output_tokens) {
+        skippy_set_error(out_error, SKIPPY_STATUS_BUFFER_TOO_SMALL, "fused MTP output token buffer is too small");
+        return SKIPPY_STATUS_BUFFER_TOO_SMALL;
+    }
+
+    std::vector<llama_token> verify_inputs;
+    verify_inputs.reserve(1 + draft_tokens.size());
+    verify_inputs.push_back(current);
+    if (verify_extra_sample) {
+        verify_inputs.insert(verify_inputs.end(), draft_tokens.begin(), draft_tokens.end());
+    } else {
+        verify_inputs.insert(verify_inputs.end(), draft_tokens.begin(), draft_tokens.end() - 1);
+    }
+
+    uint64_t checkpoint_tokens = 0;
+    const int64_t checkpoint_start_us = ggml_time_us();
+    status = skippy_checkpoint_session(target_session, &checkpoint_tokens, out_error);
+    out_result->checkpoint_ms += static_cast<double>(ggml_time_us() - checkpoint_start_us) / 1000.0;
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    out_result->checkpoint_calls += 1;
+
+    std::vector<llama_token> predicted_tokens(verify_inputs.size());
+    size_t predicted_count = 0;
+    const int64_t verify_start_us = ggml_time_us();
+    status = skippy_verify_tokens(
+            target_session,
+            verify_inputs.data(),
+            verify_inputs.size(),
+            predicted_tokens.data(),
+            predicted_tokens.size(),
+            &predicted_count,
+            out_error);
+    out_result->primary_verify_ms += static_cast<double>(ggml_time_us() - verify_start_us) / 1000.0;
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    out_result->target_verify_decode_calls += 1;
+    out_result->target_verify_tokens += static_cast<uint32_t>(verify_inputs.size());
+    predicted_tokens.resize(predicted_count);
+    const size_t expected_predictions = draft_tokens.size() + (verify_extra_sample ? 1 : 0);
+    if (predicted_tokens.size() < expected_predictions) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "fused MTP verify returned too few tokens");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+
+    out_result->windows = 1;
+    size_t accepted_before_reject = 0;
+    bool rejected = false;
+    bool accepted_stop = false;
+    for (size_t i = 0; i < draft_tokens.size(); ++i) {
+        const bool accepted = predicted_tokens[i] == draft_tokens[i];
+        const bool reached_eog = llama_vocab_is_eog(vocab, predicted_tokens[i]);
+        const bool reached_limit = 1 + i + (verify_extra_sample ? 1 : 0) >= max_new_tokens;
+        if (accepted) {
+            accepted_before_reject++;
+            if (reached_eog || reached_limit) {
+                accepted_stop = true;
+                break;
+            }
+            continue;
+        }
+        rejected = true;
+        break;
+    }
+
+    out_result->accepted_tokens = static_cast<uint32_t>(accepted_before_reject);
+    if (rejected) {
+        out_result->rejected_tokens = 1;
+        out_result->rejected_windows = 1;
+        if (accepted_before_reject + 1 < draft_tokens.size()) {
+            out_result->early_reject_windows = 1;
+        } else {
+            out_result->tail_reject_windows = 1;
+        }
+        out_result->repair_required_windows = 1;
+    } else if (!accepted_stop) {
+        out_result->full_accept_windows = 1;
+    }
+
+    if (!rejected) {
+        const int64_t verify_ingest_start_us = ggml_time_us();
+        float * h_verify = llama_get_embeddings_pre_norm(target_session->ctx);
+        if (h_verify == nullptr) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "target pre-norm embeddings were not captured for fused MTP verify");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+        status = skippy_mtp_session_ingest(
+                mtp_session,
+                verify_inputs.data(),
+                verify_inputs.size(),
+                h_verify,
+                verify_inputs.size() * static_cast<size_t>(mtp_session->head->n_embd) * sizeof(float),
+                static_cast<llama_pos>(checkpoint_tokens),
+                out_error);
+        out_result->mtp_ingest_ms += static_cast<double>(ggml_time_us() - verify_ingest_start_us) / 1000.0;
+        if (status != SKIPPY_STATUS_OK) {
+            return status;
+        }
+        out_result->mtp_ingest_calls += 1;
+        out_result->mtp_ingest_tokens += static_cast<uint32_t>(verify_inputs.size());
+        const size_t append_count = verify_extra_sample && !accepted_stop ?
+                std::min(predicted_tokens.size(), max_new_tokens - 1) :
+                std::min(accepted_before_reject, max_new_tokens - 1);
+        for (size_t i = 0; i < append_count; ++i) {
+            output_tokens[1 + i] = predicted_tokens[i];
+        }
+        out_result->committed_count = static_cast<uint32_t>(1 + append_count);
+        return skippy_success(out_error);
+    }
+
+    const int64_t repair_start_us = ggml_time_us();
+    const int64_t restore_start_us = ggml_time_us();
+    status = skippy_restore_session_checkpoint(target_session, checkpoint_tokens, out_error);
+    out_result->restore_ms += static_cast<double>(ggml_time_us() - restore_start_us) / 1000.0;
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    out_result->restore_calls += 1;
+    const size_t repair_input_count = accepted_before_reject + 1;
+    if (repair_input_count == 1) {
+        status = skippy_decode_tokens(target_session, &current, 1, true, out_error);
+        if (status != SKIPPY_STATUS_OK) {
+            return status;
+        }
+        out_result->target_repair_decode_calls += 1;
+        out_result->target_repair_tokens += 1;
+        output_tokens[1] = skippy_sample_token(target_session, sampling);
+        out_result->committed_count = 2;
+    } else {
+        std::vector<llama_token> repaired_predictions(repair_input_count);
+        size_t repaired_count = 0;
+        status = skippy_verify_tokens(
+                target_session,
+                verify_inputs.data(),
+                repair_input_count,
+                repaired_predictions.data(),
+                repaired_predictions.size(),
+                &repaired_count,
+                out_error);
+        if (status != SKIPPY_STATUS_OK) {
+            return status;
+        }
+        out_result->target_repair_decode_calls += 1;
+        out_result->target_repair_tokens += static_cast<uint32_t>(repair_input_count);
+        if (repaired_count < repair_input_count) {
+            skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "fused MTP repair returned too few tokens");
+            return SKIPPY_STATUS_RUNTIME_ERROR;
+        }
+        for (size_t i = 0; i < repair_input_count; ++i) {
+            output_tokens[1 + i] = repaired_predictions[i];
+        }
+        out_result->committed_count = static_cast<uint32_t>(1 + repair_input_count);
+    }
+    const int64_t repair_ingest_start_us = ggml_time_us();
+    float * h_repair = llama_get_embeddings_pre_norm(target_session->ctx);
+    if (h_repair == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "target pre-norm embeddings were not captured for fused MTP repair");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    status = skippy_mtp_session_ingest(
+            mtp_session,
+            verify_inputs.data(),
+            repair_input_count,
+            h_repair,
+            repair_input_count * static_cast<size_t>(mtp_session->head->n_embd) * sizeof(float),
+            static_cast<llama_pos>(checkpoint_tokens),
+            out_error);
+    out_result->mtp_ingest_ms += static_cast<double>(ggml_time_us() - repair_ingest_start_us) / 1000.0;
+    if (status != SKIPPY_STATUS_OK) {
+        return status;
+    }
+    out_result->mtp_ingest_calls += 1;
+    out_result->mtp_ingest_tokens += static_cast<uint32_t>(repair_input_count);
+    out_result->repair_ms += static_cast<double>(ggml_time_us() - repair_start_us) / 1000.0;
+    return skippy_success(out_error);
+}
+
+static void skippy_mtp_accumulate_decode_result(
+        skippy_mtp_decode_result * dst,
+        const skippy_mtp_decode_result & src) {
+    dst->committed_count += src.committed_count;
+    dst->proposed_tokens += src.proposed_tokens;
+    dst->accepted_tokens += src.accepted_tokens;
+    dst->rejected_tokens += src.rejected_tokens;
+    dst->windows += src.windows;
+    dst->full_accept_windows += src.full_accept_windows;
+    dst->tail_reject_windows += src.tail_reject_windows;
+    dst->early_reject_windows += src.early_reject_windows;
+    dst->repair_required_windows += src.repair_required_windows;
+    dst->rejected_windows += src.rejected_windows;
+    dst->mtp_disabled = dst->mtp_disabled || src.mtp_disabled;
+    dst->target_decode_calls += src.target_decode_calls;
+    dst->target_verify_decode_calls += src.target_verify_decode_calls;
+    dst->target_verify_tokens += src.target_verify_tokens;
+    dst->target_repair_decode_calls += src.target_repair_decode_calls;
+    dst->target_repair_tokens += src.target_repair_tokens;
+    dst->mtp_ingest_calls += src.mtp_ingest_calls;
+    dst->mtp_ingest_tokens += src.mtp_ingest_tokens;
+    dst->mtp_draft_calls += src.mtp_draft_calls;
+    dst->mtp_draft_decode_calls += src.mtp_draft_decode_calls;
+    dst->mtp_draft_tokens += src.mtp_draft_tokens;
+    dst->checkpoint_calls += src.checkpoint_calls;
+    dst->restore_calls += src.restore_calls;
+    dst->target_decode_ms += src.target_decode_ms;
+    dst->mtp_ingest_ms += src.mtp_ingest_ms;
+    dst->mtp_propose_ms += src.mtp_propose_ms;
+    dst->primary_verify_ms += src.primary_verify_ms;
+    dst->repair_ms += src.repair_ms;
+    dst->checkpoint_ms += src.checkpoint_ms;
+    dst->restore_ms += src.restore_ms;
+}
+
+enum skippy_status skippy_mtp_generate_span(
+        struct skippy_session * target_session,
+        struct skippy_mtp_session * mtp_session,
+        llama_token input_token,
+        const struct skippy_sampling_config * sampling,
+        size_t max_new_tokens,
+        size_t max_speculative_tokens,
+        bool mtp_enabled,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_decode_result * out_result,
+        struct skippy_error ** out_error) {
+    if (out_result != nullptr) {
+        *out_result = {};
+        out_result->version = 1;
+    }
+    if (target_session == nullptr || target_session->ctx == nullptr || output_tokens == nullptr || out_result == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "target_session, output_tokens, and out_result are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (max_new_tokens == 0 || output_token_capacity == 0) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "max_new_tokens and output capacity must be non-zero");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    const size_t capacity = std::min(max_new_tokens, output_token_capacity);
+    llama_token current_input = input_token;
+    bool step_mtp_enabled = mtp_enabled;
+    size_t generated = 0;
+    while (generated < capacity) {
+        skippy_mtp_decode_result step_result{};
+        const size_t remaining = capacity - generated;
+        enum skippy_status status = skippy_mtp_decode_step(
+                target_session,
+                mtp_session,
+                current_input,
+                sampling,
+                remaining,
+                max_speculative_tokens,
+                step_mtp_enabled,
+                output_tokens + generated,
+                remaining,
+                &step_result,
+                out_error);
+        if (status != SKIPPY_STATUS_OK) {
+            return status;
+        }
+        skippy_mtp_accumulate_decode_result(out_result, step_result);
+        const size_t committed = static_cast<size_t>(step_result.committed_count);
+        if (committed == 0) {
+            break;
+        }
+        generated += committed;
+        current_input = output_tokens[generated - 1];
+        if (step_result.mtp_disabled) {
+            step_mtp_enabled = false;
+        }
+    }
+    out_result->committed_count = static_cast<uint32_t>(generated);
+    return skippy_success(out_error);
+}
