+static float skippy_mtp_top_probability(const float * logits, int32_t n_vocab, llama_token top_id, uint32_t top_k) {
+    if (logits == nullptr || n_vocab <= 0 || top_id < 0 || top_id >= n_vocab) {
+        return 0.0f;
+    }
+    if (top_k == 0 || top_k >= static_cast<uint32_t>(n_vocab)) {
+        float max_logit = logits[0];
+        for (int32_t i = 1; i < n_vocab; ++i) {
+            max_logit = std::max(max_logit, logits[i]);
+        }
+        double denom = 0.0;
+        for (int32_t i = 0; i < n_vocab; ++i) {
+            denom += std::exp(static_cast<double>(logits[i] - max_logit));
+        }
+        if (denom <= 0.0) {
+            return 0.0f;
+        }
+        return static_cast<float>(std::exp(static_cast<double>(logits[top_id] - max_logit)) / denom);
+    }
+
+    const int32_t k = static_cast<int32_t>(std::min<uint32_t>(top_k, static_cast<uint32_t>(n_vocab)));
+    std::vector<float> top_logits;
+    top_logits.reserve(static_cast<size_t>(k));
+    for (int32_t i = 0; i < n_vocab; ++i) {
+        const float logit = logits[i];
+        if (static_cast<int32_t>(top_logits.size()) < k) {
+            top_logits.push_back(logit);
+            if (static_cast<int32_t>(top_logits.size()) == k) {
+                std::make_heap(top_logits.begin(), top_logits.end(), std::greater<float>());
+            }
+            continue;
+        }
+        if (logit > top_logits.front()) {
+            std::pop_heap(top_logits.begin(), top_logits.end(), std::greater<float>());
+            top_logits.back() = logit;
+            std::push_heap(top_logits.begin(), top_logits.end(), std::greater<float>());
+        }
+    }
+    const float max_logit = *std::max_element(top_logits.begin(), top_logits.end());
+    double denom = 0.0;
+    for (float logit : top_logits) {
+        denom += std::exp(static_cast<double>(logit - max_logit));
+    }
+    if (denom <= 0.0) {
+        return 0.0f;
+    }
+    return static_cast<float>(std::exp(static_cast<double>(logits[top_id] - max_logit)) / denom);
+}
