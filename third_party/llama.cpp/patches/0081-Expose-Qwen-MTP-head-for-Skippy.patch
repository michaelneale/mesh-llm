+static std::string skippy_mtp_arch_for_path(const char * path) {
+    if (path == nullptr) {
+        return {};
+    }
+
+    gguf_init_params params = {
+        /*.no_alloc =*/ true,
+        /*.ctx      =*/ nullptr,
+    };
+    gguf_context * ctx = gguf_init_from_file(path, params);
+    if (ctx == nullptr) {
+        return {};
+    }
+
+    auto cleanup = [&]() {
+        gguf_free(ctx);
+    };
+
+    const int arch_idx = gguf_find_key(ctx, "general.architecture");
+    if (arch_idx < 0 || gguf_get_kv_type(ctx, arch_idx) != GGUF_TYPE_STRING) {
+        cleanup();
+        return {};
+    }
+    const std::string arch = gguf_get_val_str(ctx, arch_idx);
+    const int nextn_idx = gguf_find_key(ctx, (arch + ".nextn_predict_layers").c_str());
+    if (nextn_idx < 0 || gguf_get_kv_type(ctx, nextn_idx) != GGUF_TYPE_UINT32 || gguf_get_val_u32(ctx, nextn_idx) == 0) {
+        cleanup();
+        return {};
+    }
+
+    cleanup();
+    if (arch == "qwen35") {
+        return "qwen35_mtp";
+    }
+    if (arch == "qwen35moe") {
+        return "qwen35moe_mtp";
+    }
+    return {};
