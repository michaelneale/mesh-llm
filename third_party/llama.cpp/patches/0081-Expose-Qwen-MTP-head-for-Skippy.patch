diff --git a/include/skippy/mtp.h b/include/skippy/mtp.h
new file mode 100644
index 00000000..5c47c961
--- /dev/null
+++ b/include/skippy/mtp.h
@@ -0,0 +1,209 @@
+#ifndef SKIPPY_MTP_ABI_H
+#define SKIPPY_MTP_ABI_H
+
+#include "skippy.h"
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+// Experimental ABI for Skippy-owned MTP integration.
+//
+// The MTP head is loaded from the same GGUF as the target trunk and consumes
+// target hidden state before the final output norm. Keep this surface separate
+// from skippy.h so staged serving can feature-probe and evolve MTP without
+// changing the core stage ABI.
+
+#define SKIPPY_MTP_ABI_VERSION_MAJOR 0
+#define SKIPPY_MTP_ABI_VERSION_MINOR 1
+#define SKIPPY_MTP_ABI_VERSION_PATCH 0
+
+struct skippy_mtp_abi_version {
+    uint32_t major;
+    uint32_t minor;
+    uint32_t patch;
+};
+
+struct skippy_mtp_head;
+struct skippy_mtp_session;
+
+struct skippy_mtp_params {
+    uint32_t version;
+    uint32_t n_min;
+    uint32_t n_max;
+    uint32_t top_k;
+    float p_min;
+};
+
+struct skippy_mtp_draft_result {
+    uint32_t version;
+    uint32_t token_count;
+    uint32_t accepted_floor;
+    uint32_t reserved;
+};
+
+struct skippy_mtp_decode_result {
+    uint32_t version;
+    uint32_t committed_count;
+    uint32_t proposed_tokens;
+    uint32_t accepted_tokens;
+    uint32_t rejected_tokens;
+    uint32_t windows;
+    uint32_t full_accept_windows;
+    uint32_t tail_reject_windows;
+    uint32_t early_reject_windows;
+    uint32_t repair_required_windows;
+    uint32_t rejected_windows;
+    uint32_t mtp_disabled;
+    uint32_t target_decode_calls;
+    uint32_t target_verify_decode_calls;
+    uint32_t target_verify_tokens;
+    uint32_t target_repair_decode_calls;
+    uint32_t target_repair_tokens;
+    uint32_t mtp_ingest_calls;
+    uint32_t mtp_ingest_tokens;
+    uint32_t mtp_draft_calls;
+    uint32_t mtp_draft_decode_calls;
+    uint32_t mtp_draft_tokens;
+    uint32_t checkpoint_calls;
+    uint32_t restore_calls;
+    uint32_t reserved[2];
+    double target_decode_ms;
+    double mtp_ingest_ms;
+    double mtp_propose_ms;
+    double primary_verify_ms;
+    double repair_ms;
+    double checkpoint_ms;
+    double restore_ms;
+};
+
+LLAMA_API struct skippy_mtp_abi_version skippy_mtp_abi_version(void);
+
+// Returns true when the loaded target model advertises a Qwen3.5/3.6 MTP head
+// that the patched llama.cpp backend can load as a sibling architecture.
+LLAMA_API bool skippy_mtp_model_supports_head(const struct skippy_model * model);
+
+// Enable or disable extraction of trunk h_pre_norm rows from a final-stage
+// session. This must be enabled before the decode call whose hidden rows will
+// be copied.
+LLAMA_API enum skippy_status skippy_mtp_session_set_capture_pre_norm(
+        struct skippy_session * session,
+        bool enabled,
+        struct skippy_error ** out_error);
+
+// Copy the most recent h_pre_norm output rows from a final-stage session.
+// The output buffer is F32 token-major with token_count * n_embd floats.
+LLAMA_API enum skippy_status skippy_mtp_session_copy_pre_norm(
+        struct skippy_session * session,
+        uint32_t token_count,
+        void * output_payload,
+        size_t output_capacity,
+        size_t * out_output_bytes,
+        struct skippy_error ** out_error);
+
+// Open the sibling MTP head from the same GGUF as the target trunk. The caller
+// owns the returned head and must free it with skippy_mtp_head_free.
+LLAMA_API enum skippy_status skippy_mtp_head_open(
+        const char * path,
+        const struct skippy_runtime_config * target_config,
+        const struct skippy_mtp_params * params,
+        struct skippy_mtp_head ** out_head,
+        struct skippy_error ** out_error);
+
+LLAMA_API enum skippy_status skippy_mtp_head_free(
+        struct skippy_mtp_head * head,
+        struct skippy_error ** out_error);
+
+LLAMA_API enum skippy_status skippy_mtp_session_create(
+        struct skippy_mtp_head * head,
+        struct skippy_mtp_session ** out_session,
+        struct skippy_error ** out_error);
+
+LLAMA_API enum skippy_status skippy_mtp_session_free(
+        struct skippy_mtp_session * session,
+        struct skippy_error ** out_error);
+
+// Reset the sibling MTP context before synchronizing a new request.
+LLAMA_API enum skippy_status skippy_mtp_session_reset(
+        struct skippy_mtp_session * session,
+        struct skippy_error ** out_error);
+
+// Synchronize the sibling MTP context with target-model execution. The hidden
+// rows are F32 token-major h_pre_norm rows captured from the target context for
+// the same token batch. The MTP context consumes each token with the previous
+// token's hidden row, matching llama.cpp's common_speculative_state_mtp hook.
+LLAMA_API enum skippy_status skippy_mtp_session_ingest(
+        struct skippy_mtp_session * session,
+        const llama_token * token_ids,
+        size_t token_count,
+        const void * h_pre_norm_f32,
+        size_t h_pre_norm_bytes,
+        llama_pos pos_start,
+        struct skippy_error ** out_error);
+
+// Draft future tokens from a trunk h_pre_norm row plus the last accepted token.
+// This function is intentionally shaped for final-stage-local use: callers pass
+// the F32 hidden row that was captured from the target session.
+LLAMA_API enum skippy_status skippy_mtp_session_draft(
+        struct skippy_mtp_session * session,
+        const void * h_pre_norm_f32,
+        size_t h_pre_norm_bytes,
+        llama_token last_token,
+        llama_pos position,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_draft_result * out_result,
+        struct skippy_error ** out_error);
+
+// Draft future tokens from an already synchronized MTP context.
+LLAMA_API enum skippy_status skippy_mtp_session_draft_synced(
+        struct skippy_mtp_session * session,
+        llama_token last_token,
+        llama_pos position,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_draft_result * out_result,
+        struct skippy_error ** out_error);
+
+// Decode one target token, optionally run a local in-process MTP speculative
+// window, verify proposals on the target context, and return committed tokens.
+// This is the fast path for final-stage-local serving; distributed serving can
+// continue to use the explicit draft/verify ABI above.
+LLAMA_API enum skippy_status skippy_mtp_decode_step(
+        struct skippy_session * target_session,
+        struct skippy_mtp_session * mtp_session,
+        llama_token input_token,
+        const struct skippy_sampling_config * sampling,
+        size_t max_new_tokens,
+        size_t max_speculative_tokens,
+        bool mtp_enabled,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_decode_result * out_result,
+        struct skippy_error ** out_error);
+
+// Decode a contiguous local MTP span in one native call. This repeatedly runs
+// the fused decode-step contract above, feeding each committed token back into
+// the target session, and accumulates counters/timers into out_result.
+LLAMA_API enum skippy_status skippy_mtp_generate_span(
+        struct skippy_session * target_session,
+        struct skippy_mtp_session * mtp_session,
+        llama_token input_token,
+        const struct skippy_sampling_config * sampling,
+        size_t max_new_tokens,
+        size_t max_speculative_tokens,
+        bool mtp_enabled,
+        llama_token * output_tokens,
+        size_t output_token_capacity,
+        struct skippy_mtp_decode_result * out_result,
+        struct skippy_error ** out_error);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif
