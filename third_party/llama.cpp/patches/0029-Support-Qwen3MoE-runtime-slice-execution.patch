From 01d1d880fe04aadcb21abcdc5ae6b2843b1695c6 Mon Sep 17 00:00:00 2001
From: James Dumay <jameswdumay@gmail.com>
Date: Thu, 30 Apr 2026 18:55:00 +1000
Subject: [PATCH 29/45] Support Qwen3MoE runtime-slice execution

Add LLM_ARCH_QWEN3MOE to the supported architecture list in the stage
filter gate and add stage filter hooks to the qwen3moe.cpp graph builder
so that runtime-slice execution works for Qwen3MoE models.
---
 src/models/qwen3moe.cpp | 18 +++++++++++++++---
 src/skippy.cpp          |  1 +
 2 files changed, 16 insertions(+), 3 deletions(-)

diff --git a/src/models/qwen3moe.cpp b/src/models/qwen3moe.cpp
index 4440b83a..69135dfc 100644
--- a/src/models/qwen3moe.cpp
+++ b/src/models/qwen3moe.cpp
@@ -68,16 +68,21 @@ llama_model_qwen3moe::graph::graph(const llama_model & model, const llm_graph_pa
     ggml_tensor * cur;
     ggml_tensor * inpL;
 
-    inpL = build_inp_embd(model.tok_embd);
+    const skippy_graph_filter & stage_filter = skippy_graph_get_filter();
+    const bool stage_filtered = stage_filter.enabled;
+    const int il_start = stage_filtered ? stage_filter.layer_start : 0;
+    const int il_end   = stage_filtered ? stage_filter.layer_end   : n_layer;
+
+    inpL = build_inp_embd(stage_filtered && il_start > 0 ? nullptr : model.tok_embd);
 
     // inp_pos - contains the positions
     ggml_tensor * inp_pos = build_inp_pos();
 
     auto * inp_attn = build_attn_inp_kv();
 
-    ggml_tensor * inp_out_ids = build_inp_out_ids();
+    ggml_tensor * inp_out_ids = (!stage_filtered || stage_filter.include_output) ? build_inp_out_ids() : nullptr;
 
-    for (int il = 0; il < n_layer; ++il) {
+    for (int il = il_start; il < il_end; ++il) {
         ggml_tensor * inpSA = inpL;
 
         // norm
@@ -160,6 +165,13 @@ llama_model_qwen3moe::graph::graph(const llama_model & model, const llm_graph_pa
     }
     cur = inpL;
 
+    if (stage_filtered && !stage_filter.include_output) {
+        cb(cur, "stage_boundary", il_end - 1);
+        res->t_embd = cur;
+        ggml_build_forward_expand(gf, cur);
+        return;
+    }
+
     cur = build_norm(cur,
             model.output_norm, NULL,
             LLM_NORM_RMS, -1);
diff --git a/src/skippy.cpp b/src/skippy.cpp
index ab5a147c..1139464a 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1045,6 +1045,7 @@ static enum skippy_status skippy_finish_model_open(
             model->arch != LLM_ARCH_QWEN3 &&
             model->arch != LLM_ARCH_QWEN3NEXT &&
             model->arch != LLM_ARCH_QWEN35MOE &&
+            model->arch != LLM_ARCH_QWEN3MOE &&
             model->arch != LLM_ARCH_GEMMA &&
             model->arch != LLM_ARCH_GEMMA2 &&
             model->arch != LLM_ARCH_GEMMA3 &&
