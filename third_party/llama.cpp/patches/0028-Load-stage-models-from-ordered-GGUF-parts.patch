+
+struct llama_model * llama_model_load_from_parts(
+        const char * const * paths,
+        size_t n_paths,
+        struct llama_model_params params) {
+    std::vector<std::string> parts;
+    if (n_paths == 0) {
+        LLAMA_LOG_ERROR("%s: list of parts is empty\n", __func__);
+        return nullptr;
+    }
+    parts.reserve(n_paths);
+    for (size_t i = 0; i < n_paths; ++i) {
+        if (paths[i] == nullptr) {
+            LLAMA_LOG_ERROR("%s: part path %zu is NULL\n", __func__, i);
+            return nullptr;
+        }
+        parts.push_back(paths[i]);
+    }
+    return llama_model_load_from_file_impl(nullptr, nullptr, nullptr, parts.front(), parts, /*ordered_parts*/ true, /*file*/ nullptr, params);
 }
 
