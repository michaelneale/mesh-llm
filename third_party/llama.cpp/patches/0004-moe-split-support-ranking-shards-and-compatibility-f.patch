+// Snake draft: sort experts by score descending, then distribute to groups
+// in snake order (0,1,2,3,3,2,1,0,0,1,2,3,...) so each group gets balanced mix
+static std::vector<std::vector<int>> snake_draft(
+        const std::vector<double> & scores,
+        int n_groups) {
+    int n = (int)scores.size();
+
+    // Sort expert indices by score (descending)
+    std::vector<int> ranked(n);
+    std::iota(ranked.begin(), ranked.end(), 0);
+    std::sort(ranked.begin(), ranked.end(),
+        [&](int a, int b) { return scores[a] > scores[b]; });
+
+    std::vector<std::vector<int>> groups(n_groups);
+    for (int i = 0; i < n; i++) {
+        // Snake: round = i / n_groups, position in round = i % n_groups
+        int round = i / n_groups;
+        int pos   = i % n_groups;
+        int group = (round % 2 == 0) ? pos : (n_groups - 1 - pos);
+        groups[group].push_back(ranked[i]);
+    }
+
+    // Sort each group's expert IDs for cleaner output
+    for (auto & g : groups) {
+        std::sort(g.begin(), g.end());
+    }
+
+    // Print balance statistics
+    printf("\n  Snake draft balance:\n");
+    for (int g = 0; g < n_groups; g++) {
+        double sum = 0;
+        for (int e : groups[g]) sum += scores[e];
+        printf("    Group %d: %d experts, total norm = %.2f, mean norm = %.3f\n",
+            g, (int)groups[g].size(), sum, sum / groups[g].size());
+    }
+
+    return groups;
+}
