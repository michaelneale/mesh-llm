+// Read group map file: one group per line, comma-separated expert IDs
+// Lines starting with # are comments, empty lines are skipped
+static std::vector<std::vector<int>> read_group_map(const std::string & path) {
+    std::vector<std::vector<int>> groups;
+    std::ifstream f(path);
+    if (!f.is_open()) {
+        fprintf(stderr, "error: cannot open group map file: %s\n", path.c_str());
+        exit(1);
+    }
+    std::string line;
+    while (std::getline(f, line)) {
+        // skip comments and empty lines
+        size_t start = line.find_first_not_of(" \t");
+        if (start == std::string::npos) continue;
+        if (line[start] == '#') continue;
+        auto ids = parse_int_list(line);
+        if (!ids.empty()) {
+            groups.push_back(std::move(ids));
+        }
+    }
+    return groups;
+}
