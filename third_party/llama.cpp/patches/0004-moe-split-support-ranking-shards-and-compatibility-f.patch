+// Read ranking CSV from moe-analyze: expert_id,gate_mass,mass_pct,selection_count
+// Returns vector of {expert_id, gate_mass} sorted by mass descending
+static std::vector<std::pair<int,double>> read_ranking_file(const std::string & path) {
+    std::vector<std::pair<int,double>> result;
+    std::ifstream f(path);
+    if (!f.is_open()) {
+        fprintf(stderr, "error: cannot open ranking file: %s\n", path.c_str());
+        exit(1);
+    }
+    std::string line;
+    while (std::getline(f, line)) {
+        if (line.empty() || line[0] == '#') continue;
+        int id;
+        double mass;
+        if (sscanf(line.c_str(), "%d,%lf", &id, &mass) >= 2) {
+            result.push_back({id, mass});
+        }
     }
     return result;
 }
