+// Compute per-expert average L2 norm across all router gate layers.
+// Router gates are [n_embd, n_expert] F32 tensors — each row (column in logical
+// layout) is an expert's routing weight vector. We compute ||w_e||_2 for each
+// expert e, averaged across layers.
+static std::vector<double> compute_gate_norms(
+        const std::vector<input_shard> & input_shards,
+        int n_expert) {
+    std::vector<double> norm_sum(n_expert, 0.0);
+    int n_layers = 0;
+
+    for (const auto & input_shard : input_shards) {
+        std::ifstream f_in(input_shard.path, std::ios::binary);
+        if (!f_in.is_open()) {
+            fprintf(stderr, "error: cannot open %s\n", input_shard.path.c_str());
+            exit(1);
+        }
+
+        int n_tensors = gguf_get_n_tensors(input_shard.ctx_gguf);
+        for (int i = 0; i < n_tensors; i++) {
+            const char * name = gguf_get_tensor_name(input_shard.ctx_gguf, i);
+            if (!is_router_gate(name)) continue;
+
+            struct ggml_tensor * t = ggml_get_tensor(input_shard.ctx_meta, name);
+
+            // Router gate shape: [n_embd, n_expert] — ne[0]=n_embd, ne[1]=n_expert
+            int n_embd_gate = (int) t->ne[0];
+            int n_exp_gate  = (int) t->ne[1];
+
+            if (n_exp_gate != n_expert) {
+                fprintf(stderr, "warning: gate %s has %d experts, expected %d. Skipping.\n",
+                    name, n_exp_gate, n_expert);
+                continue;
+            }
+
+            // Read gate data — must be F32 for norm computation
+            if (t->type != GGML_TYPE_F32) {
+                fprintf(stderr, "warning: gate %s is type %d (not F32). Skipping norm analysis.\n",
+                    name, t->type);
+                continue;
+            }
+
+            size_t offset =
+                gguf_get_data_offset(input_shard.ctx_gguf) +
+                gguf_get_tensor_offset(input_shard.ctx_gguf, i);
+            size_t n_bytes = (size_t) n_embd_gate * n_exp_gate * sizeof(float);
+            std::vector<float> data(n_embd_gate * n_exp_gate);
+            f_in.seekg(offset);
+            f_in.read((char *) data.data(), n_bytes);
+
+            // Compute L2 norm per expert
+            // Memory layout: expert e's weights are at data[e * n_embd .. (e+1) * n_embd)
+            // (row-major, each "row" in memory is one expert's embedding-dim vector)
+            for (int e = 0; e < n_expert; e++) {
+                double sum_sq = 0;
+                for (int d = 0; d < n_embd_gate; d++) {
+                    float v = data[e * n_embd_gate + d];
+                    sum_sq += (double) v * v;
+                }
+                norm_sum[e] += std::sqrt(sum_sq);
+            }
+            n_layers++;
+        }
+    }
+
+    // Average across layers
+    if (n_layers > 0) {
+        for (int e = 0; e < n_expert; e++) {
+            norm_sum[e] /= n_layers;
+        }
+    }
+
+    printf("  Computed gate norms across %d layers\n", n_layers);
+    return norm_sum;
+}
