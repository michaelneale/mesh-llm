+static bool gguf_split_path_for_index(
+        const std::string & first_path,
+        uint16_t first_idx,
+        uint16_t idx,
+        uint16_t n_split,
+        std::string & out) {
+    char first_suffix[32];
+    snprintf(first_suffix, sizeof(first_suffix), "-%05u-of-%05u.gguf",
+             (unsigned) first_idx + 1, (unsigned) n_split);
+
+    if (first_path.size() < strlen(first_suffix)) {
+        return false;
+    }
+
+    size_t suffix_pos = first_path.size() - strlen(first_suffix);
+    if (first_path.compare(suffix_pos, std::string::npos, first_suffix) != 0) {
+        return false;
+    }
+
+    char suffix[32];
+    snprintf(suffix, sizeof(suffix), "-%05u-of-%05u.gguf",
+             (unsigned) idx + 1, (unsigned) n_split);
+    out = first_path.substr(0, suffix_pos) + suffix;
+    return true;
+}
+
+bool rpc_server::ensure_gguf_index() {
+    if (!gguf_files.empty()) {
+        return true;
+    }
+
+    if (gguf_path.empty()) {
+        return false;
+    }
+
+    struct gguf_init_params gparams = { /*.no_alloc =*/ true, /*.ctx =*/ nullptr };
+    gguf_context_ptr first_ctx { gguf_init_from_file(gguf_path.c_str(), gparams) };
+    if (!first_ctx) {
+        GGML_LOG_ERROR("[%s] failed to parse GGUF file: %s\n", __func__, gguf_path.c_str());
+        gguf_path.clear(); // don't try again
+        return false;
+    }
+
+    uint16_t first_idx = 0;
+    if (int64_t key = gguf_find_key(first_ctx.get(), "split.no"); key >= 0) {
+        first_idx = gguf_get_val_u16(first_ctx.get(), key);
+    }
+
+    uint16_t n_split = 1;
+    if (int64_t key = gguf_find_key(first_ctx.get(), "split.count"); key >= 0) {
+        n_split = gguf_get_val_u16(first_ctx.get(), key);
+    }
+
+    gguf_files.push_back({gguf_path, std::move(first_ctx)});
+
+    if (n_split > 1) {
+        for (uint16_t idx = 0; idx < n_split; ++idx) {
+            if (idx == first_idx) {
+                continue;
+            }
+
+            std::string split_path;
+            if (!gguf_split_path_for_index(gguf_path, first_idx, idx, n_split, split_path)) {
+                GGML_LOG_ERROR("[%s] failed to derive GGUF split path from %s (split %u/%u)\n",
+                               __func__, gguf_path.c_str(), (unsigned) idx + 1, (unsigned) n_split);
+                continue;
+            }
+
+            gguf_context_ptr split_ctx { gguf_init_from_file(split_path.c_str(), gparams) };
+            if (!split_ctx) {
+                GGML_LOG_ERROR("[%s] failed to parse GGUF split: %s\n", __func__, split_path.c_str());
+                continue;
+            }
+
+            if (int64_t key = gguf_find_key(split_ctx.get(), "split.no"); key >= 0) {
+                uint16_t split_no = gguf_get_val_u16(split_ctx.get(), key);
+                if (split_no != idx) {
+                    GGML_LOG_ERROR("[%s] GGUF split has index %u, expected %u: %s\n",
+                                   __func__, (unsigned) split_no, (unsigned) idx, split_path.c_str());
+                    continue;
+                }
+            }
+
+            gguf_files.push_back({split_path, std::move(split_ctx)});
+        }
+    }
+
+    int64_t n_tensors = 0;
+    for (const gguf_file & file : gguf_files) {
+        n_tensors += gguf_get_n_tensors(file.ctx.get());
+    }
+    GGML_LOG_INFO("[%s] indexed %zu GGUF file(s) from %s (%" PRId64 " tensors)\n",
+                  __func__, gguf_files.size(), gguf_path.c_str(), n_tensors);
+
+    return true;
+}
