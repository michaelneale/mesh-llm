+    const int tid = threadIdx.x;
+    const float neighbor = __shfl_xor_sync(0xFFFFFFFFULL, val, 1);
+    if ((tid & 1) == 0) {
+        const half2 packed = __floats2half2_rn(val, neighbor);
+        *((half2 *)(dst_base + tid)) = packed;
+    }
+}
