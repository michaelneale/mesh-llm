+struct rpc_msg_push_tensor_to_peer_req {
+    uint32_t   peer_id;
+    rpc_tensor src;
+    rpc_tensor dst;
+    uint64_t   offset;
+    uint64_t   size;
+};
+
+struct rpc_msg_push_tensor_to_peer_rsp {
+    uint8_t result;
+};
