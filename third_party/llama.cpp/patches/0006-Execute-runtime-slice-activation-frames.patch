diff --git a/src/skippy.cpp b/src/skippy.cpp
index 4aef362a..732a1a15 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1,6 +1,8 @@
 #include "skippy.h"
 
 #include "gguf.h"
