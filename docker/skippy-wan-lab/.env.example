# The lab defaults to this HF layer package. The host-side launcher downloads
# it into the host Hugging Face cache before Docker starts containers.
MODEL_PACKAGE_REF=hf://meshllm/gemma-4-26B-A4B-it-UD-Q4_K_M-layers

# Public model id exposed by stage0's OpenAI endpoint.
MODEL_ID=unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q4_K_M

# Package manifest constants.
LAYER_COUNT=30
ACTIVATION_WIDTH=2816

# Linux netem shape applied to stage-network egress in each stage container.
# Set either WAN_DELAY_MS as one-way delay or WAN_RTT_MS as measured ping RTT.
WAN_DELAY_MS=
WAN_RTT_MS=
WAN_JITTER_MS=0
WAN_RATE_MBIT=
WAN_LOSS_PERCENT=0

# Runtime and serving knobs.
CTX_SIZE=512
STAGE_LANES=1
STAGE_MAX_INFLIGHT=1
LOAD_MODE=layer-package
ACTIVATION_WIRE_DTYPE=f16
OPENAI_DEFAULT_MAX_TOKENS=32
OPENAI_GENERATION_CONCURRENCY=1
OPENAI_PREFILL_CHUNK_POLICY=adaptive-ramp
OPENAI_PREFILL_CHUNK_SIZE=256
ASYNC_PREFILL_FORWARD=0

# Host ports.
OPENAI_PORT=9337
METRICS_HTTP_PORT=18080
METRICS_OTLP_GRPC_PORT=14317
